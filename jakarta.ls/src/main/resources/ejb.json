{
	"Jakarta EJB - message-driven bean": {
		"prefix": "ejb_messagedriven_bean",
		"body": [
			"package ${1:packagename};",
			"",
			"import jakarta.ejb.ActivationConfigProperty;",
			"import jakarta.ejb.MessageDriven;",
			"import jakarta.jms.Message;",
			"import jakarta.jms.MessageListener;",
			"",
			"@MessageDriven(",
			"\tactivationConfig = {",
			"\t\t@ActivationConfigProperty(propertyName = \"${2:destinationLookup}\", propertyValue = \"${3:jms/Queue}\")",
			"\t}",
			")",
			"public class ${TM_FILENAME_BASE} implements MessageListener {",
			"",
			"\t@Override",
			"\tpublic void onMessage(Message message) {",
			"\t\tSystem.out.println(\"Received message: \" + message);",
			"\t}",
			"}"
		],
		"description": "Message-Driven Bean",
		"context": {
			"type": "jakarta.jms.MessageListener",
			"contentType": "class"
		}
	},
	"Jakarta EJB - timer service with programmatic scheduling": {
		"prefix": "ejb_timer_programmatic",
		"body": [
			"package ${1:packagename};",
			"",
			"import jakarta.annotation.Resource;",
			"import jakarta.ejb.Singleton;",
			"import jakarta.ejb.Startup;",
			"import jakarta.ejb.Timeout;",
			"import jakarta.ejb.Timer;",
			"import jakarta.ejb.TimerConfig;",
			"import jakarta.ejb.TimerService;",
			"",
			"/**",
			" * EJB Timer Service example demonstrating programmatic timer scheduling.",
			" * This singleton bean creates timers dynamically using the TimerService API.",
			" */",
			"@Singleton",
			"@Startup",
			"public class ${TM_FILENAME_BASE} {",
			"",
			"\t@Resource",
			"\tprivate TimerService timerService;",
			"",
			"\t/**",
			"\t * Creates a programmatic timer that expires after a specified duration.",
			"\t * This method demonstrates how to create a single-action timer using TimerService.",
			"\t */",
			"\tpublic void ${2:createTimer}() {",
			"\t\t// Create a single-action timer that expires after 5 seconds",
			"\t\tTimerConfig timerConfig = new TimerConfig();",
			"\t\ttimerConfig.setInfo(\"${3:MyTimer}\");",
			"\t\ttimerConfig.setPersistent(false);",
			"\t\ttimerService.createSingleActionTimer(5000, timerConfig);",
			"\t}",
			"",
			"\t/**",
			"\t * Callback method invoked when the timer expires.",
			"\t * ",
			"\t * @param timer the timer that expired",
			"\t */",
			"\t@Timeout",
			"\tpublic void ${4:handleTimeout}(Timer timer) {",
			"\t\tSystem.out.println(\"Timer expired: \" + timer.getInfo());",
			"\t}",
			"}"
		],
		"description": "EJB Timer Service with programmatic scheduling",
		"context": {
			"type": "jakarta.ejb.TimerService",
			"contentType": "class"
		}
	}
}