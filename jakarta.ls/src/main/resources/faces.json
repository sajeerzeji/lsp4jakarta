			"",
			"\t/**",
			"\t * Decodes the behavior from the request.",
			"\t * ",
			"\t * @param context the FacesContext for the current request",
			"\t * @param component the UIComponent associated with this behavior",
			"\t */",
			"\t@Override",
			"\tpublic void decode(FacesContext context, UIComponent component) {",
			"\t\t// ${3:custom decode logic}",
			"\t}",
			"}"
		],
		"description": "Custom JSF behavior with @FacesBehavior annotation",
		"context": {
			"type": "jakarta.faces.component.behavior.ClientBehaviorBase",
