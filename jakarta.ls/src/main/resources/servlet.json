	"Jakarta Servlet - MultipartConfig": {
		"prefix": "servlet_multipartconfig",
		"body": [
			"package ${1:packagename};",
			"",
			"import jakarta.servlet.ServletException;",
			"import jakarta.servlet.annotation.MultipartConfig;",
			"import jakarta.servlet.annotation.WebServlet;",
			"import jakarta.servlet.http.HttpServlet;",
			"import jakarta.servlet.http.HttpServletRequest;",
			"import jakarta.servlet.http.HttpServletResponse;",
			"import jakarta.servlet.http.Part;",
			"",
			"import java.io.IOException;",
			"",
			"@WebServlet(name = \"${2:servletName}\", urlPatterns = { \"/${3:upload}\" })",
			"@MultipartConfig(",
			"\tfileSizeThreshold = 1024 * 1024,",
			"\tmaxFileSize = 1024 * 1024 * 5,",
			"\tmaxRequestSize = 1024 * 1024 * 1",
			")",
			"public class ${TM_FILENAME_BASE} extends HttpServlet {",
			"\t@Override",
			"\tprotected void doPost(HttpServletRequest request, HttpServletResponse response) throws IOException, ServletException {",
			"\t\tPart filePart = request.getPart(\"file\"); // Retrieves <input type=\"file\" name=\"file\">",
			"\t\tString fileName = filePart.getSubmittedFileName();",
			"\t\t// Process the file...",
			"\t}",
			"}"
		],
		"description": "Servlet MultipartConfig",
        		"context": {
			"type": "jakarta.servlet.http.HttpServlet",
			"contentType": "class"
		}
    },
	"Jakarta Servlet - WebListener": {
		"prefix": "servlet_weblistener",
		"body": [
			"package ${1:packagename};",
			"",
			"import jakarta.servlet.annotation.WebListener;",
			"import jakarta.servlet.ServletContextEvent;",
			"import jakarta.servlet.ServletContextListener;",
			"",
			"@WebListener",
			"public class ${TM_FILENAME_BASE} implements ServletContextListener {",
			"\t@Override",
			"\tpublic void contextInitialized(ServletContextEvent sce) {",
			"\t\tSystem.out.println(\"Context initialized: \" + sce.getServletContext().getContextPath());",
			"\t}",
			"\t@Override",
			"\tpublic void contextDestroyed(ServletContextEvent sce) {",
			"\t\tSystem.out.println(\"Context destroyed: \" + sce.getServletContext().getContextPath());",
			"\t}",
			"}"
		],
		"description": "Servlet WebListener",
		"context": {
			"type": "jakarta.servlet.ServletContextListener",
            "contentType": "class"
			}
	},
	"Jakarta Servlet - ServletSecurity": {
		"prefix": "servlet_security",
		"body": [
			"package ${1:packagename};",
			"",
			"import jakarta.servlet.annotation.ServletSecurity;",
			"import jakarta.servlet.annotation.WebServlet;",
			"import jakarta.servlet.annotation.HttpConstraint;",
			"import jakarta.servlet.annotation.HttpMethodConstraint;",
			"import jakarta.servlet.http.HttpServlet;",
			"import jakarta.servlet.http.HttpServletRequest;",
			"import jakarta.servlet.http.HttpServletResponse;",
			"import jakarta.servlet.ServletException;",
			"",
			"import java.io.IOException;",
			"",
			"@WebServlet(\"${2:servletName}\")",
			"@ServletSecurity(",
			"\tvalue = @HttpConstraint(rolesAllowed = {\"admin\"}),",
			"\thttpMethodConstraints = {",
			"\t\t@HttpMethodConstraint(value = \"GET\", rolesAllowed = {\"user\", \"admin\"}),",
			"\t\t@HttpMethodConstraint(value = \"POST\", rolesAllowed = {\"admin\"})",
			"\t}",
			")",
			"public class ${TM_FILENAME_BASE} extends HttpServlet {",
			"\t@Override",
			"\tprotected void doGet(HttpServletRequest request, HttpServletResponse response) throws IOException, ServletException{",
			"\t\tresponse.getWriter().write(\"GET access granted\");",
			"\t}",
			"\t@Override",
			"\tprotected void doPost(HttpServletRequest request, HttpServletResponse response) throws IOException, ServletException{",
			"\t\tresponse.getWriter().write(\"POST access granted\");",
			"\t}",
			"}"
		],
		"description": "Enforce security constraints directly on servlets",
		"context": {
			"type": "jakarta.servlet.http.HttpServlet",
			"contentType": "class"
		}
	},
	"Jakarta Servlet - DataSourceDefinition": {
		"prefix": "servlet_datasource_definition",
		"body": [
			"package ${1:packagename};",
			"",
			"import jakarta.annotation.sql.DataSourceDefinition;",
			"",
			"@DataSourceDefinition(",
			"\tname = \"java:app/jdbc/${2:MyDS}\",",
			"\tclassName = \"${3:org.h2.Driver}\",",
			"\t// Option 1: Use url for complete JDBC connection string (remove Option 2 if using this)",
			"\turl = \"${4:jdbc:h2:mem:test;DB_CLOSE_DELAY=-1}\",",
			"\t// Option 2: Or use serverName and portNumber instead of url (remove Option 1 if using this)",
			"\tserverName = \"${5:localhost}\",",
			"\tportNumber = ${6:1527},",
			"\tuser = \"${7:sa}\",",
			"\tpassword = \"${8:secret}\"",
			")",
			"public class ${TM_FILENAME_BASE} {",
			"\t// This class is used only for declaring the DataSource",
			"}"
		],
		"description": "Define a DataSource using @DataSourceDefinition annotation",
		"context": {
			"type": "jakarta.annotation.sql.DataSourceDefinition",
			"contentType": "class"
		}
	}
}